---
import { File, Github, Gitlab, Linkedin, Mail } from 'lucide-react'
import Card from '../Card.astro'
import { Button } from '../ui/button'
import { LINKS } from '../../lib/constants'
---

<Card colSpan="md:col-span-2 lg:col-span-1" rowSpan="md:row-span-2 lg:row-span-2" title="Kontakt">
  <section id="kontakt" class="mt-2 space-y-4">
    <p class="m-0 text-sm text-muted-foreground">
      Wenn Sie Unterstützung für ein komplexes System-, Architektur- oder Modernisierungsvorhaben suchen, schicken Sie mir kurz den
      Kontext. Ich melde mich zeitnah mit einer realistischen Einschätzung.
    </p>

    <div class="space-y-3">
      <a href="mailto:sergej@goerzen.consulting?subject=Projektanfrage%20Softwarearchitektur%20und%20Delivery">
        <Button className="w-full justify-start">
          <Mail />
          <span class="ml-2">sergej@goerzen.consulting</span>
        </Button>
      </a>
      <a href={LINKS.calendly} target="_blank" rel="noreferrer">
        <Button variant="outline" className="w-full justify-start">
          <File />
          <span class="ml-2">30 Min Erstgespräch</span>
        </Button>
      </a>
    </div>

    <div class="space-y-2">
      <p class="m-0 text-xs font-semibold uppercase tracking-wide text-muted-foreground">Profile</p>
      <div class="flex flex-wrap gap-2">
        <a href={LINKS.linkedin} aria-label="linkedin profile" target="_blank" rel="noreferrer">
          <Button variant="outline" size="icon" aria-label="linkedin profile">
            <Linkedin />
          </Button>
        </a>
        <a href={LINKS.github} aria-label="github profile" target="_blank" rel="noreferrer">
          <Button variant="outline" size="icon" aria-label="github profile">
            <Github />
          </Button>
        </a>
        <a href={LINKS.gitlab} aria-label="gitlab profile" target="_blank" rel="noreferrer">
          <Button variant="outline" size="icon" aria-label="gitlab profile">
            <Gitlab />
          </Button>
        </a>
      </div>
    </div>

    <p class="m-0 text-xs text-muted-foreground">CV auf Anfrage für konkrete Projektanfragen.</p>
  </section>
</Card>
