---
import Card from '../Card.astro'
import { SERVICES } from '../../lib/constants'
---

<Card colSpan="md:col-span-2 lg:col-span-4" rowSpan="md:row-span-1 lg:row-span-1" title="Leistungen" body="Klar abgegrenzte Unterstützung für anspruchsvolle technische Vorhaben.">
  <section id="leistungen" class="mt-4 grid gap-4 md:grid-cols-3">
    {
      SERVICES.map((service) => (
        <article class="rounded-xl border p-4">
          <h3 class="m-0 text-lg font-semibold">{service.title}</h3>
          <p class="mt-2 text-sm text-muted-foreground">{service.description}</p>
          <ul class="mt-3 list-disc space-y-1 pl-5 text-sm text-muted-foreground">
            {service.bullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        </article>
      ))
    }
  </section>
</Card>
