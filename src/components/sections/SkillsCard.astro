---
import Card from '../Card.astro'
import { Badge } from '../ui/badge'
---

<Card colSpan="md:col-span-2 lg:col-span-1" rowSpan="md:row-span-2 lg:row-span-2" title="Fokus & Zielkunden">
  <section class="mt-2 space-y-4" id="fokus">
    <div class="flex flex-col gap-2">
      <h3 class="text-sm font-semibold text-muted-foreground">Technischer Fokus</h3>
      <div class="flex w-full flex-wrap gap-2">
        <Badge variant="outline">C#/.NET Backend</Badge>
        <Badge variant="outline">Architektur</Badge>
        <Badge variant="outline">Modernisierung</Badge>
        <Badge variant="outline">Refactoring</Badge>
        <Badge variant="outline">Integrationen</Badge>
        <Badge variant="outline">Performance</Badge>
        <Badge variant="outline">Tech Delivery</Badge>
      </div>
    </div>

    <div class="flex flex-col gap-2">
      <h3 class="text-sm font-semibold text-muted-foreground">Typische Kunden</h3>
      <div class="space-y-2 text-sm text-muted-foreground">
        <p class="m-0">Mittelständische Unternehmen mit gewachsenen Systemen</p>
        <p class="m-0">Produktteams mit Architektur- oder Delivery-Problemen</p>
        <p class="m-0">Vorhaben mit komplexen .NET-/Backend-/Integrationsanforderungen</p>
      </div>
    </div>

    <div class="flex flex-col gap-2">
      <h3 class="text-sm font-semibold text-muted-foreground">Differenzierung</h3>
      <div class="space-y-2 text-sm text-muted-foreground">
        <p class="m-0">XR/Unity/AR als gezielter Produktbaustein, nicht als Selbstzweck.</p>
      </div>
    </div>
  </section>
</Card>
