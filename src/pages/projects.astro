---
import { PROJECTS, CASE_STUDIES } from '../lib/constants'
import BaseLayout from '../layouts/BaseLayout.astro'
import TopLayout from '../layouts/TopLayout.astro'
import BottomLayout from '../layouts/BottomLayout.astro'
import { Home } from 'lucide-react'
---

<BaseLayout title={PROJECTS.TITLE} description={PROJECTS.DESCRIPTION}>
  <main class="flex min-h-[80vh] flex-auto flex-col" transition:animate="fade">
    <TopLayout>
      <div>
        <a href="/" aria-label="Startseite">
          <Home />
        </a>
      </div>
      <h2 class="scroll-m-20 border-b pb-2 text-3xl font-semibold tracking-tight first:mt-0">
        {PROJECTS.TITLE}
      </h2>
    </TopLayout>

    <BottomLayout>
      <div class="space-y-4">
        <p class="max-w-3xl text-sm text-muted-foreground">
          Die Beispiele zeigen typische Problemklassen aus realen Projekten: gewachsene Architekturen, technische Schulden,
          Integrationsrisiken und anspruchsvolle Delivery-Situationen.
        </p>

        {
          CASE_STUDIES.map((entry) => (
            <article class="rounded-xl border p-5">
              <p class="m-0 text-xs font-semibold uppercase tracking-wide text-muted-foreground">{entry.client}</p>
              <h3 class="mt-1 text-xl font-semibold">{entry.title}</h3>
              <p class="mt-3 text-sm"><span class="font-semibold">Ausgangslage:</span> {entry.challenge}</p>
              <p class="mt-2 text-sm"><span class="font-semibold">Vorgehen:</span> {entry.approach}</p>
              <p class="mt-2 text-sm"><span class="font-semibold">Ergebnis:</span> {entry.result}</p>
              <p class="mt-3 text-xs text-muted-foreground">Fokus: {entry.focus}</p>
            </article>
          ))
        }
      </div>
    </BottomLayout>
  </main>
</BaseLayout>
